---
interface Props {
  heroTag: string;
  heroTitle: string;
  heroDescription: string;
  statAccess: string;
  statGateway: string;
}

const { heroTag, heroTitle, heroDescription, statAccess, statGateway } = Astro.props;
---

<section aria-label="Hero overview" class="terminal-panel terminal-hero reveal-up">
  <p class="text-xs uppercase tracking-[0.24em] text-terminal-cyan">{heroTag}</p>
  <h1 class="mt-3 text-4xl font-bold tracking-tight text-terminal-green md:text-6xl">{heroTitle}</h1>
  <p class="mt-5 max-w-3xl text-sm leading-7 text-terminal-muted md:text-base">
    {heroDescription}
  </p>
  <div class="mt-7 grid gap-3 sm:grid-cols-3">
    <div class="stat-chip">
      <p class="stat-label">Agents</p>
      <p id="hero-agent-count" class="stat-value">-</p>
    </div>
    <div class="stat-chip">
      <p class="stat-label">Gateway</p>
      <p class="stat-value">{statGateway}</p>
    </div>
    <div class="stat-chip">
      <p class="stat-label">Access</p>
      <p class="stat-value">{statAccess}</p>
    </div>
  </div>
  <div class="mt-6 inline-flex items-center gap-3 rounded-full border border-terminal-border bg-terminal-surface-2 px-3 py-1 text-xs text-terminal-muted">
    <span id="hero-status-dot" class="h-2 w-2 rounded-full bg-terminal-muted" aria-hidden="true"></span>
    <span id="hero-status-text">Waiting for gateway...</span>
  </div>
</section>
