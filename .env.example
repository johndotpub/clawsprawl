# --- Server-side gateway connection (SSR mode) ---
# The Astro SSR server connects to the OpenClaw gateway.
# The browser NEVER holds the gateway token.

# Gateway WebSocket URL (server-side connection)
# OPENCLAW_GATEWAY_WS_URL=ws://localhost:18789/ws

# Gateway HTTP URL (server-side SSE event stream)
# OPENCLAW_GATEWAY_HTTP_URL=http://localhost:18789

# Gateway auth token (required for operator scopes).
# The same token used in your openclaw.json gateway.auth.token field.
# Server-side only — never exposed to the browser.
OPENCLAW_GATEWAY_TOKEN=

# Optional comma-separated scopes override (server-side only).
# Default is least-privilege read-only: operator.read
# Example: OPENCLAW_GATEWAY_SCOPES=operator.read,operator.write
# OPENCLAW_GATEWAY_SCOPES=

# --- ClawSprawl access mode ---
# public   = public dashboard only
# token    = public dashboard + bearer-token-protected private view
# insecure = public + private dashboard fully visible (private-network-only)
# WARNING: Do NOT commit .env files containing CLAWSPRAWL_MODE=insecure to version control.
#          The insecure mode bypasses authentication and should only be used in
#          trusted private-network environments.
CLAWSPRAWL_MODE=public

# Separate bearer token for unlocking private dashboard cards in token mode.
# This is NOT the gateway token. The browser submits it once to
# `/api/private/session`, then the server mints an httpOnly session cookie.
# CLAWSPRAWL_PRIVATE_TOKEN=   # Minimum 32 characters recommended; use `openssl rand -hex 16`

# Maximum private session lifetime in hours for token mode.
# Values above 24 are clamped to 24.
# CLAWSPRAWL_SESSION_MAX_AGE_HOURS=24

# --- Dashboard branding ---
PUBLIC_MAINFRAME_PROFILE=sprawl-lab
# Bundled profiles: sprawl-lab, public-demo
# Private local option: private-local via src/config/profiles/*.local.ts

# --- Server configuration ---
# HOST=127.0.0.1
# PORT=4321

# Public site URL for canonical/OG/Twitter metadata (used by Astro `site` config).
# PUBLIC_SITE_URL=http://localhost:4321

# Trust X-Forwarded-For header for client IP extraction (rate limiting).
# Only enable when behind a trusted proxy that overwrites this header.
# CLAWSPRAWL_TRUST_PROXY=0

# --- Gateway client identity (v4 device auth) ---
# The dashboard connects to the gateway via WebSocket. On gateways that enforce
# device identity (v4+), you must either:
#   a) Use the reserved loopback backend path (default): CLAWSPRAWL_CLIENT_ID=gateway-client
#      CLAWSPRAWL_CLIENT_MODE=backend  (works on loopback only, no device pairing needed)
#   b) Pair a device and send its identity + signed nonce:
#      CLAWSPRAWL_DEVICE_ID=<your-device-id>
#      CLAWSPRAWL_DEVICE_PUBLIC_KEY=<ed25519-public-key-pem>
#      CLAWSPRAWL_DEVICE_PRIVATE_KEY=<ed25519-private-key-pem>
#      CLAWSPRAWL_DEVICE_TOKEN=<device-token-from-pairing>
# CLAWSPRAWL_CLIENT_ID=openclaw-control-ui
# CLAWSPRAWL_CLIENT_MODE=webchat
